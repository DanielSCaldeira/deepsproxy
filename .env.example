# --- Server ---
# Port the proxy listens on (default: 3000)
PORT=3000

# Bind host. If unset and API_KEY is unset, defaults to 127.0.0.1 (loopback).
# Setting BIND_HOST to a non-loopback value WITHOUT API_KEY will refuse to start.
# BIND_HOST=0.0.0.0

# API key for protecting endpoints (recommended whenever BIND_HOST is non-loopback).
# Clients send it via "Authorization: Bearer <key>" or "X-API-Key: <key>".
# API_KEY=replace-me-with-a-strong-secret

# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info

# --- Playwright ---
# Run Chromium headless (default: true). Set to "false" only for debugging.
PLAYWRIGHT_HEADLESS=true

# Directory used as the persistent Chromium profile (relative to cwd).
# DEEPSEEK_PROFILE_DIR=deepseek_profile

# How long to wait for the DeepSeek chat input to appear before giving up (ms).
# DEEPSPROXY_CHAT_INPUT_TIMEOUT_MS=8000

# How long to wait for the PoW interception to fire (ms).
# DEEPSPROXY_POW_TIMEOUT_MS=30000

# User agent advertised by the embedded Chromium.
# DEEPSEEK_USER_AGENT=Mozilla/5.0 ...

# --- DeepSeek client headers (mirrored to upstream requests) ---
# DEEPSEEK_APP_VERSION=2.0.0
# DEEPSEEK_CLIENT_VERSION=2.0.0
# DEEPSEEK_CLIENT_LOCALE=pt_BR
# DEEPSEEK_ACCEPT_LANGUAGE=pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7

# --- Retry / telemetry ---
# Max retry attempts per chat request (default: 3)
# DEEPSPROXY_MAX_ATTEMPTS=3
# Delay between retries in ms (default: 1000)
# DEEPSPROXY_RETRY_DELAY_MS=1000

# Where the auto-detected context-window stats are persisted.
# Defaults to <DEEPSEEK_PROFILE_DIR>/.telemetry.json
# DEEPSPROXY_TELEMETRY_FILE=

# Disable telemetry persistence entirely (set to "1").
# DEEPSPROXY_DISABLE_TELEMETRY_PERSIST=0
